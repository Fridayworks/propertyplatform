using Xunit;
using PropertyPlatform.Core.Entities;
using PropertyPlatform.Infrastructure.Data;
using Microsoft.EntityFrameworkCore;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;

namespace PropertyPlatform.Tests
{
    public class SecurityComplianceTests : IAsyncLifetime
    {
        private ApplicationDbContext _context;

        public async Task InitializeAsync()
        {
            var options = new DbContextOptionsBuilder<ApplicationDbContext>()
                .UseInMemoryDatabase(databaseName: $"PropertyPlatformTest_Security_{Guid.NewGuid()}")
                .Options;

            _context = new ApplicationDbContext(options);
            await SeedTestData();
        }

        public async Task DisposeAsync()
        {
            await _context.DisposeAsync();
        }

        private async Task SeedTestData()
        {
            // Seed test tenant and listing
            var tenant = new Tenant
            {
                TenantId = Guid.NewGuid(),
                Name = "Security Test Agent",
                Email = "securityagent@test.com",
                IsActive = true,
                CreatedAt = DateTime.UtcNow
            };

            var listing = new PropertyListing
            {
                ListingId = Guid.NewGuid(),
                Title = "Secure Property",
                Location = "Boston, MA",
                Price = 3200,
                Bedrooms = 2,
                SquareFootage = 1300,
                PropertyType = "Apartment",
                Status = "Active",
                TenantId = tenant.TenantId,
                CreatedAt = DateTime.UtcNow,
                Media = new List<PropertyMedia>()
            };

            _context.Tenants.Add(tenant);
            _context.PropertyListings.Add(listing);
            await _context.SaveChangesAsync();
        }

        /// <summary>
        /// SEC_001: Unauthenticated user attempts to access protected resources
        /// Expected: Access denied; error 401 Unauthorized returned
        /// </summary>
        [Fact]
        public void UnauthenticatedAccess_ToProtectedResource_ShouldReturnUnauthorized()
        {
            // Arrange
            var token = (string)null;

            // Act & Assert
            var isAuthenticated = !string.IsNullOrEmpty(token);
            Assert.False(isAuthenticated, "Unauthenticated requests should not have token");
        }

        /// <summary>
        /// SEC_002: Authenticated user attempts to access another tenant's data
        /// Expected: Access denied; error 403 Forbidden returned
        /// </summary>
        [Fact]
        public async Task UnauthorizedDataAccess_ToOtherTenantData_ShouldReturnForbidden()
        {
            // Arrange
            var authenticatedTenantId = _context.Tenants.First().TenantId;
            var otherTenantId = Guid.NewGuid();

            var listingFromOtherTenant = new PropertyListing
            {
                ListingId = Guid.NewGuid(),
                Title = "Other Tenant's Property",
                Location = "Chicago, IL",
                Price = 3800,
                Bedrooms = 3,
                SquareFootage = 1800,
                PropertyType = "House",
                Status = "Active",
                TenantId = otherTenantId,
                CreatedAt = DateTime.UtcNow,
                Media = new List<PropertyMedia>()
            };

            _context.PropertyListings.Add(listingFromOtherTenant);
            await _context.SaveChangesAsync();

            // Act - Verify tenant can only see their own listings
            var userOwnListings = await _context.PropertyListings
                .Where(l => l.TenantId == authenticatedTenantId)
                .CountAsync();

            var otherListings = await _context.PropertyListings
                .Where(l => l.TenantId == otherTenantId)
                .CountAsync();

            // Assert
            Assert.True(userOwnListings > 0, "User should have listings");
            Assert.True(otherListings > 0, "Other tenant listings should exist");
            
            // Verify authorization - authenticated user cannot access other tenant's data
            var canAccessOtherTenantData = await _context.PropertyListings
                .AnyAsync(l => l.TenantId == otherTenantId && l.TenantId == authenticatedTenantId);

            Assert.False(canAccessOtherTenantData, "User should not access other tenant's data");
        }

        /// <summary>
        /// SEC_003: System detects malicious file upload (executable, script)
        /// Expected: File rejected; error returned; no file persisted
        /// </summary>
        [Fact]
        public void MaliciousFileUpload_WithExecutableContent_ShouldBeRejected()
        {
            // Arrange
            var maliciousFileExtensions = new[] { ".exe", ".bat", ".cmd", ".ps1", ".sh" };
            var uploadedFileName = "malicious.exe";

            // Act - Verify file is rejected
            var fileExtension = System.IO.Path.GetExtension(uploadedFileName).ToLower();
            var isAllowed = !maliciousFileExtensions.Contains(fileExtension);

            // Assert
            Assert.False(isAllowed, "Executable files should not be allowed");
        }

        /// <summary>
        /// Additional Security: SQL Injection prevention test
        /// Expected: Parameterized queries prevent injection attacks
        /// </summary>
        [Fact]
        public async Task SearchWithSQLInjectionAttempt_ShouldNotExecuteInjectedCode()
        {
            // Arrange
            var injectionAttempt = "'; DROP TABLE PropertyListings; --";

            // Act - Use parameterized query (EF Core does this by default)
            var listings = await _context.PropertyListings
                .Where(l => l.Title.Contains(injectionAttempt))
                .ToListAsync();

            // Assert - Table should still exist and be queryable
            var tableStillExists = await _context.PropertyListings.AnyAsync();
            Assert.True(listings != null, "Query should execute safely");
            // Table should not be dropped
        }

        /// <summary>
        /// Additional Security: Cross-Site Scripting (XSS) prevention
        /// Expected: HTML/JS in property description is encoded
        /// </summary>
        [Fact]
        public async Task PropertyDescription_WithXSSPayload_ShouldBeEncoded()
        {
            // Arrange
            var listing = _context.PropertyListings.First();
            var xssPayload = "<script>alert('XSS')</script>";

            // Act
            listing.Description = xssPayload;
            _context.PropertyListings.Update(listing);
            await _context.SaveChangesAsync();

            var savedListing = await _context.PropertyListings
                .FirstAsync(l => l.ListingId == listing.ListingId);

            // Assert - Payload should be stored as-is (encoding happens at presentation layer)
            Assert.Equal(xssPayload, savedListing.Description);
            // In real scenario, rendering layer would encode this
        }
    }
}
