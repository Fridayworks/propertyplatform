using Xunit;
using PropertyPlatform.Core.Entities;
using PropertyPlatform.Infrastructure.Data;
using Microsoft.EntityFrameworkCore;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;

namespace PropertyPlatform.Tests
{
    public class SmartListingEngineTests : IAsyncLifetime
    {
        private ApplicationDbContext _context;

        public async Task InitializeAsync()
        {
            var options = new DbContextOptionsBuilder<ApplicationDbContext>()
                .UseInMemoryDatabase(databaseName: $"PropertyPlatformTest_Smart_{Guid.NewGuid()}")
                .Options;

            _context = new ApplicationDbContext(options);
            await SeedTestData();
        }

        public async Task DisposeAsync()
        {
            await _context.DisposeAsync();
        }

        private async Task SeedTestData()
        {
            // Seed test tenant and listing
            var tenant = new Tenant
            {
                TenantId = Guid.NewGuid(),
                Email = "aiagent@test.com",
                PasswordHash = "hashed",
                CreatedAt = DateTime.UtcNow
            };

            var listing = new PropertyListing
            {
                ListingId = Guid.NewGuid(),
                Title = "Modern Apartment",
                Location = "San Francisco, CA",
                Price = 3500,
                PropertyType = "Condo",
                Status = "Active",
                TenantId = tenant.TenantId,
                CreatedAt = DateTime.UtcNow,
                Media = new List<PropertyMedia>()
            };

            _context.Tenants.Add(tenant);
            _context.PropertyListings.Add(listing);
            await _context.SaveChangesAsync();
        }

        /// <summary>
        /// SMART_001: System generates AI-powered description for listing
        /// Expected: Description generated and saved to database
        /// </summary>
        [Fact]
        public async Task GenerateDescription_WithListingData_ShouldCreateAIDescription()
        {
            // Arrange
            var listing = _context.PropertyListings.First();
            var aiGeneratedDescription = "This stunning 2-bedroom, 1,100 sqft apartment in San Francisco offers " +
                "modern amenities, bright natural light, and proximity to downtown. Perfect for professionals.";

            // Act
            listing.Description = aiGeneratedDescription;
            _context.PropertyListings.Update(listing);
            await _context.SaveChangesAsync();

            var updatedListing = _context.PropertyListings
                .FirstOrDefault(l => l.ListingId == listing.ListingId);

            // Assert
            Assert.NotNull(updatedListing);
            Assert.NotNull(updatedListing.Description);
            Assert.Contains("2-bedroom", updatedListing.Description);
            Assert.Contains("San Francisco", updatedListing.Description);
            Assert.Equal(aiGeneratedDescription, updatedListing.Description);
        }

        /// <summary>
        /// SMART_002: Agent edits AI-generated description and can undo
        /// Expected: Description updated; version history maintained
        /// </summary>
        [Fact]
        public async Task EditDescription_WithUndoCapability_ShouldMaintainVersionHistory()
        {
            // Arrange
            var listing = _context.PropertyListings.First();
            var originalDescription = "Original AI description";
            var editedDescription = "Agent-edited description with custom details";

            listing.Description = originalDescription;
            await _context.SaveChangesAsync();

            // Act - Simulate edit
            var previousVersion = listing.Description;
            listing.Description = editedDescription;
            await _context.SaveChangesAsync();

            // Assert
            var updatedListing = _context.PropertyListings
                .FirstOrDefault(l => l.ListingId == listing.ListingId);

            Assert.NotNull(updatedListing);
            Assert.Equal(editedDescription, updatedListing.Description);
            Assert.NotEqual(previousVersion, updatedListing.Description);
        }

        /// <summary>
        /// SMART_003: System generates design theme recommendations for listing
        /// Expected: Theme suggestions stored and accessible
        /// </summary>
        [Fact]
        public async Task GenerateTheme_ForListing_ShouldCreateDesignRecommendations()
        {
            // Arrange
            var listing = _context.PropertyListings.First();

            // Act - Simulate theme storage (using listing description for now)
            listing.Description = "Modern theme with blue and white color scheme";
            _context.PropertyListings.Update(listing);
            await _context.SaveChangesAsync();

            var updatedListing = _context.PropertyListings
                .FirstOrDefault(l => l.ListingId == listing.ListingId);

            // Assert
            Assert.NotNull(updatedListing);
            Assert.NotNull(updatedListing.Description);
            Assert.Contains("Modern", updatedListing.Description);
            Assert.Contains("blue", updatedListing.Description);
        }
    }
}
