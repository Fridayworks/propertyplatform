@page
@model PropertyPlatform.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="bg-gray-50 py-12 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Agent Profile</h1>
            <p class="mt-2 text-sm text-gray-500">Update your public identity and contact information.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded text-sm">
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="bg-white p-8 rounded-lg shadow-sm border border-gray-200">
            <form method="post" enctype="multipart/form-data" class="space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0">
                            @if (!string.IsNullOrEmpty(Model.Profile.ProfilePhotoUrl))
                            {
                                <img class="h-20 w-20 rounded-full object-cover border-2 border-primary-100" src="@Model.Profile.ProfilePhotoUrl" alt="Profile photo">
                            }
                            else
                            {
                                <div class="h-20 w-20 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 text-2xl font-bold">
                                    @(Model.Profile.Name?.FirstOrDefault().ToString().ToUpper() ?? "?")
                                </div>
                            }
                        </div>
                        <div class="flex-1">
                            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Profile Photo</label>
                            <input type="file" name="Photo" class="block w-full text-xs text-gray-500 file:mr-3 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100" accept="image/*">
                        </div>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="flex-shrink-0">
                            @if (!string.IsNullOrEmpty(Model.Profile.CompanyLogoUrl))
                            {
                                <img class="h-20 w-20 rounded object-contain border border-gray-200 p-1" src="@Model.Profile.CompanyLogoUrl" alt="Company logo">
                            }
                            else
                            {
                                <div class="h-20 w-20 rounded bg-gray-100 flex items-center justify-center text-gray-400">
                                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke-width="2" /></svg>
                                </div>
                            }
                        </div>
                        <div class="flex-1">
                            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Company Logo</label>
                            <input type="file" name="CompanyLogo" class="block w-full text-xs text-gray-500 file:mr-3 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100" accept="image/*">
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Profile.Name" class="block text-sm font-medium text-gray-700">Full Name</label>
                        <input asp-for="Profile.Name" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm px-3 py-2 border" required />
                    </div>
                    <div>
                        <label asp-for="Profile.Phone" class="block text-sm font-medium text-gray-700">Phone Number</label>
                        <input asp-for="Profile.Phone" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm px-3 py-2 border" required />
                    </div>
                </div>

                <div>
                    <label asp-for="Profile.REN_ID" class="block text-sm font-medium text-gray-700">REN ID (Real Estate Negotiator ID)</label>
                    <input asp-for="Profile.REN_ID" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm px-3 py-2 border" required />
                </div>

                <div>
                    <label asp-for="Profile.OfficeAddress" class="block text-sm font-medium text-gray-700">Office Address</label>
                    <textarea asp-for="Profile.OfficeAddress" rows="3" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm px-3 py-2 border"></textarea>
                </div>

                <div class="pt-4 border-t border-gray-200">
                    <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                        Update Profile
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
