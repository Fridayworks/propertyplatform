@page
@model PropertyPlatform.Web.Pages.CompareModel
@{
    ViewData["Title"] = "Compare Properties";
    var minPrice = Model.Properties.Any() ? Model.Properties.Min(p => p.Price) : 0;
}

<div class="bg-gray-50 py-12 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-12 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Property Comparison</h1>
                <p class="mt-2 text-sm text-gray-500">Analyze features and prices side-by-side.</p>
            </div>
            <a href="/Search" class="text-sm font-medium text-primary-600 hover:underline">&larr; Back to Search</a>
        </div>

        @if (!Model.Properties.Any())
        {
            <div class="text-center py-24 bg-white rounded-3xl border border-dashed border-gray-300">
                <p class="text-gray-500 mb-6">No properties selected for comparison.</p>
                <a href="/Search" class="bg-primary-600 text-white px-8 py-3 rounded-full font-bold shadow-lg hover:bg-primary-700 transition-all">Find Properties</a>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <div class="min-w-[800px] bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                    <table class="w-full border-collapse">
                        <thead>
                            <tr class="border-b border-gray-100">
                                <th class="w-1/4 p-6 bg-gray-50/50 text-left align-top">
                                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Property Details</p>
                                </th>
                                @foreach (var property in Model.Properties)
                                {
                                    <th class="w-1/4 p-6 text-left align-top border-l border-gray-50">
                                        <div class="relative group h-40 rounded-xl overflow-hidden mb-4">
                                            <img src="@(property.Media.FirstOrDefault()?.MediaUrl ?? "/img/placeholder.jpg")" class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                            <button onclick="ComparisonTool.remove('@property.ListingId'); window.location.reload();" class="absolute top-2 right-2 bg-black/50 backdrop-blur-md text-white rounded-full h-6 w-6 flex items-center justify-center text-xs hover:bg-red-500 transition-colors">×</button>
                                        </div>
                                        <h3 class="text-sm font-bold text-gray-900 line-clamp-2 mb-2">@property.Title</h3>
                                        <p class="text-xs text-gray-500 flex items-center">
                                            <svg class="h-3 w-3 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-width="2"/></svg>
                                            @property.Location
                                        </p>
                                    </th>
                                }
                                @for (int i = 0; i < 4 - Model.Properties.Count; i++)
                                {
                                    <th class="w-1/4 p-6 border-l border-gray-50 bg-gray-50/30">
                                        <div class="h-40 rounded-xl border-2 border-dashed border-gray-200 flex items-center justify-center text-gray-300">
                                            Empty Slot
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            <!-- Basic Specs -->
                            <tr class="border-b border-gray-50">
                                <td class="p-6 font-semibold text-gray-700 bg-gray-50/50">Price</td>
                                @foreach (var property in Model.Properties)
                                {
                                    <td class="p-6 border-l border-gray-50">
                                        <p class="text-lg font-bold @(property.Price == minPrice ? "text-green-600" : "text-gray-900")">
                                            RM @property.Price.ToString("N0")
                                            @if (property.Price == minPrice) { <span class="block text-[10px] text-green-500 uppercase">Best Price</span> }
                                        </p>
                                    </td>
                                }
                            </tr>
                            <tr class="border-b border-gray-50">
                                <td class="p-6 font-semibold text-gray-700 bg-gray-50/50">Property Type</td>
                                @foreach (var property in Model.Properties)
                                {
                                    <td class="p-6 border-l border-gray-50 text-gray-600">@property.PropertyType</td>
                                }
                            </tr>
                            <tr class="border-b border-gray-50">
                                <td class="p-6 font-semibold text-gray-700 bg-gray-50/50">Layout</td>
                                @foreach (var property in Model.Properties)
                                {
                                    <td class="p-6 border-l border-gray-50">
                                        <div class="flex space-x-4 text-xs font-medium text-gray-600">
                                            <span title="Bedrooms">🛏️ @(property.Features.FirstOrDefault(f => f.Key == "Bedrooms")?.Value ?? "0")</span>
                                            <span title="Bathrooms">🚿 @(property.Features.FirstOrDefault(f => f.Key == "Bathrooms")?.Value ?? "0")</span>
                                        </div>
                                    </td>
                                }
                            </tr>
                            <tr class="border-b border-gray-50">
                                <td class="p-6 font-semibold text-gray-700 bg-gray-50/50">Built-up Size</td>
                                @foreach (var property in Model.Properties)
                                {
                                    <td class="p-6 border-l border-gray-50 text-gray-600">
                                        @(property.Features.FirstOrDefault(f => f.Key == "Sqft")?.Value ?? "0") sqft
                                    </td>
                                }
                            </tr>
                            
                            <!-- Dynamic Features -->
                            @foreach (var key in Model.FeatureKeys.Where(k => k != "Bedrooms" && k != "Bathrooms" && k != "Sqft"))
                            {
                                <tr class="border-b border-gray-50">
                                    <td class="p-6 font-semibold text-gray-700 bg-gray-50/50">@key</td>
                                    @foreach (var property in Model.Properties)
                                    {
                                        <td class="p-6 border-l border-gray-50 text-gray-600">
                                            @(property.Features.FirstOrDefault(f => f.Key == key)?.Value ?? "-")
                                        </td>
                                    }
                                </tr>
                            }

                            <tr>
                                <td class="p-6 bg-gray-50/50"></td>
                                @foreach (var property in Model.Properties)
                                {
                                    <td class="p-6 border-l border-gray-50">
                                        <a href="/Listing/@property.ListingId" class="w-full inline-flex justify-center items-center px-4 py-2 border border-primary-600 rounded-lg text-xs font-bold text-primary-600 hover:bg-primary-600 hover:text-white transition-all">
                                            View Listing
                                        </a>
                                    </td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Ensure checkboxes on bar stay in sync if we came from here
        document.addEventListener('DOMContentLoaded', () => ComparisonTool.updateUI());
    </script>
}
