@page
@model PropertyPlatform.Web.Pages.AgentsModel
@{
    ViewData["Title"] = "Agent Dashboard";
}

<div class="bg-gray-50 py-8 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Agent Dashboard</h1>
                <p class="mt-2 text-sm text-gray-500">Manage your properties and leads.</p>
            </div>
            <a href="/CreateListing" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                New Listing
            </a>
        </div>

        <div class="mb-8 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                <p class="text-sm font-medium text-gray-500 uppercase">Active Listings</p>
                <p class="text-3xl font-bold text-gray-900">@Model.MyListings.Count</p>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                <p class="text-sm font-medium text-gray-500 uppercase">Total Leads</p>
                <p class="text-3xl font-bold text-primary-600">@Model.TotalLeads</p>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                <p class="text-sm font-medium text-gray-500 uppercase">Property Views</p>
                <p class="text-3xl font-bold text-gray-900">@Model.TotalViews</p>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
                <p class="text-sm font-medium text-gray-500 uppercase">Available Credits</p>
                <div class="flex items-center justify-between">
                    <p class="text-3xl font-bold text-amber-600">@Model.AgentCredits</p>
                    <a href="/Subscriptions" class="text-xs font-medium text-primary-600 hover:underline">Upgrade / Top Up</a>
                </div>
            </div>
            <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 lg:col-span-3">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h3 class="text-lg font-medium text-gray-900">Referral Program</h3>
                        <p class="text-sm text-gray-500">Share your link and get 50 credits for every new agent who joins!</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <input type="text" value="@Model.ReferralLink" readonly class="text-xs bg-gray-50 border border-gray-300 rounded px-2 py-1 w-64">
                        <button onclick="navigator.clipboard.writeText('@Model.ReferralLink'); alert('Link copied!')" class="text-xs bg-primary-600 text-white px-3 py-1 rounded hover:bg-primary-700">Copy</button>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-medium text-gray-500 uppercase">Total Referrals</p>
                        <p class="text-xl font-bold text-gray-900">@Model.TotalReferrals</p>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded text-sm">
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm">
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="grid grid-cols-1 gap-8">
            <!-- My Listings -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">

                    <div class="px-6 py-4 border-b border-gray-200">
                        <h2 class="text-lg font-medium text-gray-900">My Active Listings</h2>
                    </div>
                    <ul class="divide-y divide-gray-200">
                        @if (Model.MyListings.Any())
                        {
                            @foreach (var listing in Model.MyListings)
                            {
                                <li class="px-6 py-4 flex items-center hover:bg-gray-50">
                                    <div class="min-w-0 flex-1 flex items-center">
                                        <div class="flex-shrink-0 h-12 w-12 rounded-md bg-gray-200"></div>
                                        <div class="min-w-0 flex-1 px-4 md:grid md:grid-cols-2 md:gap-4">
                                            <div>
                                                <p class="text-sm font-medium text-primary-600 truncate">@listing.Title</p>
                                                <p class="mt-2 flex items-center text-sm text-gray-500">
                                                    <span class="truncate">@listing.Location</span>
                                                </p>
                                                @if (listing.FeaturedListing != null && listing.FeaturedListing.EndDate > DateTime.UtcNow)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800 mt-1">
                                                        <svg class="mr-1 h-2 w-2 text-amber-400 fill-current" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" /></svg>
                                                        Featured
                                                    </span>
                                                }
                                            </div>
                                            <div class="hidden md:block">
                                                <div>
                                                    <p class="text-sm text-gray-900 font-medium">RM @listing.Price.ToString("N0")</p>
                                                    <div class="flex items-center space-x-4 mt-2">
                                                        <p class="text-xs text-gray-500">Views: @(listing.Analytics?.Views ?? 0)</p>
                                                        <p class="text-xs text-gray-500">Leads: @(listing.Leads?.Count ?? 0)</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="ml-5 flex-shrink-0 flex items-center space-x-3">
                                        @if (listing.FeaturedListing == null || listing.FeaturedListing.EndDate <= DateTime.UtcNow)
                                        {
                                            <form asp-page-handler="Boost" asp-route-id="@listing.ListingId" method="post" class="inline">
                                                <button type="submit" class="text-amber-600 hover:text-amber-900 text-sm font-medium border border-amber-200 px-2 py-1 rounded bg-amber-50" onclick="return confirm('Boost this listing for 10 credits?')">Boost</button>
                                            </form>
                                        }
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 mr-2">
                                            @listing.Status
                                        </span>
                                        <a href="/EditListing/@listing.ListingId" class="text-primary-600 hover:text-primary-900 text-sm font-medium">Edit</a>
                                        <form asp-page-handler="Delete" asp-route-id="@listing.ListingId" method="post" onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                            <button type="submit" class="text-red-600 hover:text-red-900 text-sm font-medium">Delete</button>
                                        </form>
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="px-6 py-8 text-center text-gray-500 text-sm">
                                You don't have any listings yet. Create one using the form.
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
