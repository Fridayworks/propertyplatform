@page
@model PropertyPlatform.Web.Pages.Admin.UserEditModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="bg-gray-50 py-12 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Edit User</h1>
                <p class="mt-2 text-sm text-gray-500">Modify agent profile and access levels.</p>
            </div>
            <a href="/Admin/Users" class="text-sm font-medium text-primary-600 hover:text-primary-500">&larr; Back to Users</a>
        </div>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="mb-6 bg-green-50 border-l-4 border-green-400 p-4">
                <div class="flex">
                    <div class="ml-3">
                        <p class="text-sm text-green-700">@Model.SuccessMessage</p>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-6 bg-red-50 border-l-4 border-red-400 p-4">
                <div class="flex">
                    <div class="ml-3">
                        <p class="text-sm text-red-700">@Model.ErrorMessage</p>
                    </div>
                </div>
            </div>
        }

        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6">
                <form method="post">
                    <input type="hidden" asp-for="Agent.AgentId" />
                    
                    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                        <div class="sm:col-span-3">
                            <label asp-for="Agent.Name" class="block text-sm font-medium text-gray-700">Name</label>
                            <div class="mt-1">
                                <input type="text" asp-for="Agent.Name" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <div class="sm:col-span-3">
                            <label asp-for="Agent.Email" class="block text-sm font-medium text-gray-700">Email</label>
                            <div class="mt-1">
                                <input type="email" asp-for="Agent.Email" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <div class="sm:col-span-3">
                            <label asp-for="Agent.Phone" class="block text-sm font-medium text-gray-700">Phone</label>
                            <div class="mt-1">
                                <input type="text" asp-for="Agent.Phone" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <div class="sm:col-span-3">
                            <label asp-for="Agent.REN_ID" class="block text-sm font-medium text-gray-700">REN ID</label>
                            <div class="mt-1">
                                <input type="text" asp-for="Agent.REN_ID" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <div class="sm:col-span-3">
                            <label asp-for="Agent.Credits" class="block text-sm font-medium text-gray-700">Credits</label>
                            <div class="mt-1">
                                <input type="number" asp-for="Agent.Credits" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <div class="sm:col-span-3">
                            <label asp-for="Agent.Level" class="block text-sm font-medium text-gray-700">Level</label>
                            <div class="mt-1">
                                <input type="number" asp-for="Agent.Level" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <div class="sm:col-span-6">
                            <label asp-for="Agent.AdminRoleId" class="block text-sm font-medium text-gray-700">Admin Role (Optional)</label>
                            <div class="mt-1">
                                <select asp-for="Agent.AdminRoleId" asp-items="Model.AdminRoles" class="shadow-sm focus:ring-primary-500 focus:border-primary-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                    <option value="">-- No Admin Role --</option>
                                </select>
                            </div>
                            <p class="mt-2 text-sm text-gray-500">Assigning a role grants this user administrative privileges.</p>
                        </div>
                    </div>

                    <div class="mt-8 flex justify-end">
                        <a href="/Admin/Users" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                            Cancel
                        </a>
                        <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
