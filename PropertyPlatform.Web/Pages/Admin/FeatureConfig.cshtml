@page
@model PropertyPlatform.Web.Pages.Admin.FeatureConfigModel
@{
    ViewData["Title"] = "Feature Configuration";
}

<div class="bg-gray-50 py-12 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Feature Configuration</h1>
                <p class="mt-2 text-sm text-gray-500">Control which listing types agents can publish.</p>
            </div>
            <a href="/Admin" class="text-sm font-medium text-primary-600 hover:text-primary-500">&larr; Back to Admin</a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 rounded-md bg-green-50 p-4 text-sm font-medium text-green-800">
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="post" class="bg-white rounded-lg shadow-sm border border-gray-200">
            <div class="divide-y divide-gray-200">
                @foreach (var feature in Model.ListingTypes)
                {
                    <div class="p-6 flex items-start justify-between gap-6">
                        <div>
                            <h2 class="text-lg font-semibold text-gray-900">@feature.DisplayName</h2>
                            <p class="mt-1 text-sm text-gray-500">@feature.Description</p>
                            <p class="mt-2 text-xs text-gray-400">Key: @feature.FeatureKey</p>
                        </div>
                        <label class="relative inline-flex cursor-pointer items-center">
                            <input type="checkbox" name="EnabledFeatures[@feature.FeatureKey]" value="true" class="sr-only peer" checked="@feature.IsEnabled" />
                            <span class="h-6 w-11 rounded-full bg-gray-200 after:absolute after:left-0.5 after:top-0.5 after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-all peer-checked:bg-primary-600 peer-checked:after:translate-x-5"></span>
                        </label>
                    </div>
                }
            </div>
            <div class="px-6 py-4 bg-gray-50 flex justify-end">
                <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                    Save Configuration
                </button>
            </div>
        </form>
    </div>
</div>
