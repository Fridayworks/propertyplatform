@page
@model PropertyPlatform.Web.Pages.Admin.CMS.EditorModel
@{
    ViewData["Title"] = (Model.Mode == "Edit" ? "Edit Article" : "Create New Article");
}

<div class="bg-gray-50 py-12 min-h-screen">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">@ViewData["Title"]</h1>
                <p class="mt-2 text-sm text-gray-500">Draft and publish your content to the platform.</p>
            </div>
            <a href="/Admin/CMS" class="text-sm font-medium text-gray-500 hover:text-gray-700">&larr; Back to CMS</a>
        </div>

        <form method="post" class="space-y-8">
            <input type="hidden" asp-for="Article.ArticleId" />
            <input type="hidden" asp-for="Article.CreatedAt" />
            
            <div class="bg-white shadow-sm border border-gray-200 rounded-xl p-8">
                <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                    <!-- Title -->
                    <div class="sm:col-span-4">
                        <label asp-for="Article.Title" class="block text-sm font-bold text-gray-700">Article Title</label>
                        <div class="mt-1">
                            <input type="text" asp-for="Article.Title" id="article-title" onkeyup="generateSlug()" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm" placeholder="e.g. Market Trends 2026">
                        </div>
                        <span asp-validation-for="Article.Title" class="text-red-500 text-xs"></span>
                    </div>

                    <!-- Slug -->
                    <div class="sm:col-span-2">
                        <label asp-for="Article.Slug" class="block text-sm font-bold text-gray-700">URL Slug</label>
                        <div class="mt-1 flex rounded-md shadow-sm">
                            <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 bg-gray-50 text-gray-500 sm:text-xs">
                                /news/
                            </span>
                            <input type="text" asp-for="Article.Slug" id="article-slug" class="flex-1 block w-full min-w-0 border-gray-300 rounded-none rounded-r-md focus:ring-primary-500 focus:border-primary-500 sm:text-sm">
                        </div>
                        <span asp-validation-for="Article.Slug" class="text-red-500 text-xs"></span>
                    </div>

                    <!-- Excerpt -->
                    <div class="sm:col-span-6">
                        <label asp-for="Article.Excerpt" class="block text-sm font-bold text-gray-700">Excerpt / Summary</label>
                        <div class="mt-1">
                            <textarea asp-for="Article.Excerpt" rows="2" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm" placeholder="Short description for social media and listing cards..."></textarea>
                        </div>
                    </div>

                    <!-- Thumbnail URL -->
                    <div class="sm:col-span-6">
                        <label asp-for="Article.ThumbnailUrl" class="block text-sm font-bold text-gray-700">Thumbnail Image URL</label>
                        <div class="mt-1">
                            <input type="text" asp-for="Article.ThumbnailUrl" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm" placeholder="https://images.unsplash.com/...">
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="sm:col-span-6">
                        <label asp-for="Article.Content" class="block text-sm font-bold text-gray-700">Content (HTML Supported)</label>
                        <div class="mt-1">
                            <textarea asp-for="Article.Content" rows="12" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm font-mono" placeholder="<p>Write your article here...</p>"></textarea>
                        </div>
                        <p class="mt-2 text-xs text-gray-500">You can use basic HTML tags like &lt;p&gt;, &lt;h2&gt;, &lt;strong&gt;, &lt;ul&gt;, etc.</p>
                        <span asp-validation-for="Article.Content" class="text-red-500 text-xs"></span>
                    </div>

                    <!-- Author -->
                    <div class="sm:col-span-3">
                        <label asp-for="Article.Author" class="block text-sm font-bold text-gray-700">Author Name</label>
                        <div class="mt-1">
                            <input type="text" asp-for="Article.Author" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm">
                        </div>
                    </div>

                    <!-- Category -->
                    <div class="sm:col-span-3">
                        <label asp-for="Article.Category" class="block text-sm font-bold text-gray-700">Category</label>
                        <div class="mt-1">
                            <select asp-for="Article.Category" class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-primary-500 focus:border-primary-500 sm:text-sm">
                                <option value="General">General</option>
                                <option value="Company News">Company News</option>
                                <option value="Market Trends">Market Trends</option>
                                <option value="Property Guide">Property Guide</option>
                                <option value="Product Update">Product Update</option>
                            </select>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="sm:col-span-6">
                        <label asp-for="Article.Status" class="block text-sm font-bold text-gray-700">Publication Status</label>
                        <div class="mt-4 flex items-center space-x-10">
                            <div class="flex items-center">
                                <input id="status-draft" asp-for="Article.Status" type="radio" value="Draft" class="focus:ring-primary-500 h-4 w-4 text-primary-600 border-gray-300">
                                <label for="status-draft" class="ml-3 block text-sm font-medium text-gray-700">Draft (Invisible to public)</label>
                            </div>
                            <div class="flex items-center">
                                <input id="status-published" asp-for="Article.Status" type="radio" value="Published" class="focus:ring-primary-500 h-4 w-4 text-primary-600 border-gray-300">
                                <label for="status-published" class="ml-3 block text-sm font-medium text-gray-700">Published (Go live immediately)</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-4">
                <a href="/Admin/CMS" class="bg-white py-2 px-6 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors">
                    Cancel
                </a>
                <button type="submit" class="inline-flex justify-center py-2 px-10 border border-transparent shadow-sm text-sm font-bold rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-all transform hover:scale-105">
                    @(Model.Mode == "Edit" ? "Save Changes" : "Publish Article")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function generateSlug() {
            const title = document.getElementById('article-title').value;
            const slug = title.toLowerCase()
                .replace(/[^a-z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
            document.getElementById('article-slug').value = slug;
        }
    </script>
}
