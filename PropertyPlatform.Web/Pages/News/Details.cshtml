@page
@model PropertyPlatform.Web.Pages.News.DetailsModel
@{
    ViewData["Title"] = Model.Article.Title;
    ViewData["MetaDescription"] = Model.Article.Excerpt;
    ViewData["MetaImage"] = Model.Article.ThumbnailUrl;
}

<article class="bg-white min-h-screen">
    <!-- Post Header -->
    <header class="pt-16 pb-12 sm:pt-24 sm:pb-16 bg-gray-50">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <nav class="flex mb-8" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-sm text-gray-500">
                    <li><a href="/" class="hover:text-primary-600">Home</a></li>
                    <li><svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg></li>
                    <li><a href="/News" class="hover:text-primary-600">News</a></li>
                    <li><svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg></li>
                    <li class="text-gray-900 font-medium truncate">@Model.Article.Title</li>
                </ol>
            </nav>

            <span class="inline-flex items-center px-3 py-0.5 rounded-full text-sm font-bold bg-primary-100 text-primary-800 uppercase tracking-wider mb-6">
                @Model.Article.Category
            </span>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight">
                @Model.Article.Title
            </h1>
            <div class="mt-8 flex items-center">
                <div class="flex-shrink-0">
                    <div class="h-12 w-12 rounded-full bg-primary-600 flex items-center justify-center text-white font-bold text-lg">
                        @Model.Article.Author.Substring(0, 1)
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-bold text-gray-900">@Model.Article.Author</p>
                    <div class="flex space-x-1 text-sm text-gray-500">
                        <time datetime="@Model.Article.PublishedAt?.ToString("yyyy-MM-dd")">@Model.Article.PublishedAt?.ToString("MMMM dd, yyyy")</time>
                        <span aria-hidden="true">&middot;</span>
                        <span>5 min read</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrEmpty(Model.Article.ThumbnailUrl))
    {
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-12 sm:-mt-16">
            <img src="@Model.Article.ThumbnailUrl" alt="@Model.Article.Title" class="w-full h-[400px] sm:h-[500px] object-cover rounded-3xl shadow-2xl border-4 border-white">
        </div>
    }

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
        <div class="prose prose-lg prose-primary max-w-none text-gray-700 leading-relaxed">
            @Html.Raw(Model.Article.Content)
        </div>

        <!-- Share Section -->
        <div class="mt-16 pt-8 border-t border-gray-100">
            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-widest mb-6">Share this article</h3>
            <div class="flex items-center space-x-4">
                <button class="h-10 w-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-blue-50 hover:text-blue-600 transition-colors">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </button>
                <button class="h-10 w-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-sky-50 hover:text-sky-500 transition-colors">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                </button>
                <button class="h-10 w-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-gray-200 transition-colors">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Related Articles (Placeholder) -->
    <div class="bg-gray-50 py-16 sm:py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-2xl font-bold text-gray-900 mb-12">More from PropertyPlatform</h2>
            <div class="flex justify-center">
                <a href="/News" class="inline-flex items-center px-8 py-3 border border-primary-600 text-base font-bold rounded-full text-primary-600 hover:bg-primary-600 hover:text-white transition-all transform hover:scale-105 shadow-sm">
                    View all news
                </a>
            </div>
        </div>
    </div>
</article>

<style>
    .prose h2 { color: #111827; font-weight: 800; font-size: 1.5rem; margin-top: 2rem; margin-bottom: 1rem; }
    .prose p { margin-bottom: 1.5rem; }
    .prose strong { color: #111827; font-weight: 700; }
    .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .prose li { margin-bottom: 0.5rem; }
</style>
