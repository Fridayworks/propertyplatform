@page
@model PropertyPlatform.Web.Pages.SearchModel
@{
    ViewData["Title"] = "Search Properties";
}

<div class="bg-gray-50 py-8 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Search Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Find Properties</h1>
            <p class="mt-2 text-sm text-gray-500">Discover your next home from our premium listings.</p>
        </div>

        <!-- Search Form -->
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-8">
            <form method="get" class="space-y-4">
                <div class="flex flex-col sm:flex-row gap-4">
                    <div class="flex-grow">
                        <label for="query" class="sr-only">Search</label>
                        <input type="text" name="query" id="query" value="@Model.SearchQuery" 
                               class="w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 px-4 py-3 border" 
                               placeholder="Search by location or keywords...">
                    </div>
                    <button type="submit" class="inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                        Search
                    </button>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 items-end">
                    <div>
                        <label for="propertyType" class="block text-xs font-medium text-gray-500 uppercase">Property Type</label>
                        <select name="propertyType" id="propertyType" 
                                class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border">
                            <option value="">All Types</option>
                            <option value="Condo" selected="@(Model.PropertyType == "Condo")">Condo</option>
                            <option value="Terrace" selected="@(Model.PropertyType == "Terrace")">Terrace</option>
                            <option value="Semi-D" selected="@(Model.PropertyType == "Semi-D")">Semi-D</option>
                            <option value="Bungalow" selected="@(Model.PropertyType == "Bungalow")">Bungalow</option>
                            <option value="Landed" selected="@(Model.PropertyType == "Landed")">Landed</option>
                        </select>
                    </div>
                    <div>
                        <label for="minPrice" class="block text-xs font-medium text-gray-500 uppercase">Min Price (RM)</label>
                        <input type="number" name="minPrice" id="minPrice" value="@Model.MinPrice" 
                               class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border">
                    </div>
                    <div>
                        <label for="maxPrice" class="block text-xs font-medium text-gray-500 uppercase">Max Price (RM)</label>
                        <input type="number" name="maxPrice" id="maxPrice" value="@Model.MaxPrice" 
                               class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm px-3 py-2 border">
                    </div>
                </div>
            </form>
        </div>

        <!-- Results -->
        @if (Model.Listings.Any())
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var listing in Model.Listings)
                {
                    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
                        <div class="h-48 bg-gray-200 relative">
                            @if (listing.Media.Any())
                            {
                                <img src="@listing.Media.OrderBy(m => m.SortOrder).First().MediaUrl" alt="@listing.Title" class="w-full h-full object-cover">
                            }
                            else
                            {
                                <div class="absolute inset-0 flex items-center justify-center text-gray-400">
                                    <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            }
                            <div class="absolute top-2 left-2 flex flex-col gap-1">
                                @if (listing.FeaturedListing != null && listing.FeaturedListing.EndDate > DateTime.UtcNow)
                                {
                                    <div class="bg-amber-500 text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-sm flex items-center">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                        FEATURED
                                    </div>
                                }
                                <div class="bg-primary-600 text-white text-[10px] font-bold px-2 py-0.5 rounded shadow-sm w-fit">
                                    @listing.Status
                                </div>
                            </div>
                            <div class="absolute top-2 right-2">
                                <label class="flex items-center space-x-1 cursor-pointer bg-white/90 backdrop-blur-md px-2 py-1 rounded-md shadow-sm border border-gray-100 hover:bg-white transition-colors">
                                    <input type="checkbox" class="compare-toggle h-3 w-3 rounded border-gray-300 text-primary-600 focus:ring-primary-500" 
                                           data-id="@listing.ListingId" 
                                           data-title="@listing.Title" 
                                           data-image="@(listing.Media.FirstOrDefault()?.MediaUrl)"
                                           onclick="ComparisonTool.toggle('@listing.ListingId', '@listing.Title', '@(listing.Media.FirstOrDefault()?.MediaUrl)')" />
                                    <span class="text-[10px] font-bold text-gray-700">COMPARE</span>
                                </label>
                            </div>
                        </div>
                        <div class="p-5">
                            <h3 class="text-lg font-semibold text-gray-900 truncate">@listing.Title</h3>
                            <p class="text-sm text-gray-500 mt-1">@listing.Location</p>
                            <div class="mt-2 flex gap-3 text-xs text-gray-400">
                                <span>@(listing.Features.FirstOrDefault(f => f.Key == "Bedrooms")?.Value ?? "0") Beds</span>
                                <span>@(listing.Features.FirstOrDefault(f => f.Key == "Bathrooms")?.Value ?? "0") Baths</span>
                                <span>@(listing.Features.FirstOrDefault(f => f.Key == "Sqft")?.Value ?? "0") Sqft</span>
                            </div>
                            <p class="text-xl font-bold text-primary-600 mt-3">RM @listing.Price.ToString("N0")</p>
                            <div class="mt-4 flex justify-between items-center">
                                <span class="text-xs text-gray-500">@listing.CreatedAt.ToString("MMM dd, yyyy")</span>
                                <a href="/Listing/@listing.ListingId" class="text-sm font-medium text-primary-600 hover:text-primary-500">View Details &rarr;</a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-12 flex justify-center">
                    <ul class="inline-flex -space-x-px">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li>
                                <a asp-route-p="@i" 
                                   asp-route-query="@Model.SearchQuery" 
                                   asp-route-minPrice="@Model.MinPrice" 
                                   asp-route-maxPrice="@Model.MaxPrice"
                                   class="px-4 py-2 border border-gray-300 text-sm font-medium @(Model.PageNumber == i ? "bg-primary-600 text-white border-primary-600" : "bg-white text-gray-700 hover:bg-gray-50")">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-12 bg-white rounded-lg shadow-sm border border-gray-200">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900">No properties found</h3>
                <p class="mt-1 text-sm text-gray-500">Try adjusting your search or filters to find what you're looking for.</p>
            </div>
        }
    </div>
</div>
